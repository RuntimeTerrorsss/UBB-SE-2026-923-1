<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="BookingBoardgamesILoveBan.Src.PaymentCard.View.CardPaymentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BookingBoardgamesILoveBan.Src.PaymentCard.View"
    xmlns:converters="using:BookingBoardgamesILoveBan.Src.PaymentCard.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="40" MaxWidth="1000" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,32"
            FontSize="32"
            FontWeight="SemiBold"
            Text="Secure Checkout" />

        <Grid Grid.Row="1" ColumnSpacing="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="6*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="24" VerticalAlignment="Top">
                <StackPanel Spacing="16">
                    <TextBlock Text="Order Summary" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Grid RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,16,0"/>
                        <TextBlock x:ConnectionId='17' Grid.Row="0" Grid.Column="1"                                                         FontWeight="Medium" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Owner:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='18' Grid.Row="1" Grid.Column="1"                                                          FontWeight="Medium"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Dates:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='19' Grid.Row="2" Grid.Column="1"                                                             FontWeight="Medium" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Address:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='20' Grid.Row="3" Grid.Column="1"                                                                FontWeight="Medium" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Your Balance:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='21' Grid.Row="4" Grid.Column="1"                                                             FontWeight="Medium"/>
                    </Grid>

                    <MenuFlyoutSeparator Margin="0,8"/>

                    <Grid Margin="0,8,0,0">
                        <TextBlock Text="Total" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                        <TextBlock x:ConnectionId='16'                                                      FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Spacing="24">

                <StackPanel x:ConnectionId='2' x:Name="PaymentPanel" Spacing="20"
                                                                                                                                                                >

                    <TextBlock Text="Payment Details" FontSize="20" FontWeight="SemiBold"/>

                    <StackPanel Spacing="16">
                        <TextBox x:ConnectionId='12' Header="Cardholder Name" 
                                 PlaceholderText="John Doe" 
                                                                                                                                  />

                        <TextBox x:ConnectionId='13' Header="Card Number" 
                                 PlaceholderText="0000 0000 0000 0000" 
                                 MaxLength="19"
                                                                                                                              />

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:ConnectionId='14' Grid.Column="0" Header="Expiration Date" 
                                     PlaceholderText="MM/YY" MaxLength="5"
                                                                                                                                  />

                            <PasswordBox x:ConnectionId='15' Grid.Column="1" Header="CardVerificationValue" 
                                         PlaceholderText="123" MaxLength="4"
                                                                                                                                                     />
                        </Grid>
                    </StackPanel>

                    <TextBlock x:ConnectionId='6' Foreground="#E81123" 
                               Text="Insufficient account balance. Please top up your wallet."
                                                                                                                                                                 />

                    <StackPanel Spacing="16" Margin="0,16,0,0">
                        <CheckBox x:ConnectionId='7'                                                                    >
                            <TextBlock>
                                <Run Text="I agree to the " />
                                <Hyperlink x:ConnectionId='11'                         >Terms of Service</Hyperlink>
                            </TextBlock>
                        </CheckBox>

                        <Grid>
                            <Button x:ConnectionId='8' HorizontalAlignment="Left" 
                                                                                    
                                    Content="Cancel" 
                                    Style="{ThemeResource DefaultButtonStyle}"/>

                            <Button x:ConnectionId='9' HorizontalAlignment="Right" 
                                                                                             
                                                                                                             
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Width="150" Height="40">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing x:ConnectionId='10' Width="16" Height="16" Foreground="White"
                                                                                                                      
                                                                                                                                                                              />
                                    <TextBlock Text="Pay Now" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:ConnectionId='3' x:Name="SuccessPanel" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0"
                                                                                                                                                         >

                    <FontIcon Glyph="&#xE10B;" FontSize="64" Foreground="Green" Margin="0,0,0,16"/>
                    <TextBlock FontSize="24" FontWeight="Bold" Text="Payment Successful!" HorizontalAlignment="Center"/>
                    <TextBlock Text="Your transaction has been securely processed." Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>

                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,16">
                        <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                            <TextBlock Text="Remaining Balance:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:ConnectionId='5'                                                             FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Button x:ConnectionId='4' HorizontalAlignment="Center" 
                                                                            
                            Content="Return to Chat" 
                            Style="{ThemeResource AccentButtonStyle}"
                            Width="200" Height="40"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

