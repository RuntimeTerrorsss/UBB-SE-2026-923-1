<Page
    x:Class="BookingBoardgamesILoveBan.Src.Delivery.View.DeliveryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="20">
        <StackPanel MaxWidth="1000" Spacing="12" HorizontalAlignment="Center" >
            <StackPanel.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="MinWidth" Value="600"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>

                <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Red"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="4,0,0,0"/>
                </Style>
            </StackPanel.Resources>
            <!-- Title -->
            <TextBlock Text="Delivery Address"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Margin="0,0,0,8"/>
            
            <!-- Country -->
            <StackPanel Spacing="4">
                <TextBox x:ConnectionId='17' x:Name="CountryInput"
                         PlaceholderText="Country"
                         Tag="Country"
                                                     />
                <TextBlock x:ConnectionId='18' x:Name="CountryError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- City -->
            <StackPanel Spacing="4">
                <TextBox x:ConnectionId='15' x:Name="CityInput"
                         PlaceholderText="City"
                         Tag="City"
                                                     />
                <TextBlock x:ConnectionId='16' x:Name="CityError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Street -->
            <StackPanel Spacing="4">
                <TextBox x:ConnectionId='13' x:Name="StreetInput"
                         PlaceholderText="Street"
                         Tag="Street"
                                                     />
                <TextBlock x:ConnectionId='14' x:Name="StreetError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Street Number -->
            <StackPanel Spacing="4">
                <TextBox x:ConnectionId='11' x:Name="StreetNumberInput"
                         PlaceholderText="Street Number"
                         Tag="StreetNumber"
                                                     />
                <TextBlock x:ConnectionId='12' x:Name="StreetNumberError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Map button -->
            <Button x:ConnectionId='2' Content="📍 Set location on map"
                                            
                    HorizontalAlignment="Stretch"/>

            <!-- Save checkbox -->
            <CheckBox x:ConnectionId='3' Content="Save address for future orders"
                                                    
                                                        />
            <StackPanel Spacing="8" Margin="0,10,0,10">
                <TextBlock Text="Select Payment Method:" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <RadioButton x:ConnectionId='9' x:Name="CardPaymentRadio" Content="Card" IsChecked="True"/>
                    <RadioButton x:ConnectionId='10' x:Name="CashPaymentRadio" Content="Cash"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Submit -->
            <Button x:ConnectionId='4' Content="Submit Address &amp; Continue to Payment"
                                           
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"/>

            <!-- Map overlay — Visibility set in code-behind via RefreshUi() -->
            <Border x:ConnectionId='5' x:Name="MapOverlay"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="400"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WebView2 x:ConnectionId='6' x:Name="MapWebView" Grid.Row="0"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8" Margin="8">
                        <Button x:ConnectionId='7' Content="Cancel"
                                                         />
                        <Button x:ConnectionId='8' Content="Confirm location"
                                Style="{ThemeResource AccentButtonStyle}"
                                                                />
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

